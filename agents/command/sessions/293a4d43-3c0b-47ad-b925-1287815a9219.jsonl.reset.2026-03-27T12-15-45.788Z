t\": f\"你是 {category} 攻击者代理，执行渗透测试任务。请始终以 JSON 格式返回结果，包含 'success' (布尔值) 和 'data' (对象) 字段。\"},\n+138         {\"role\": \"user\", \"content\": f\"任务: {event['task']}\\n参数: {json.dumps(event.get('params', {}), indent=2)}\\n\\n请返回 JSON 格式的结果，包含以下字段：\\n- success: true/false\\n- data: 执行结果的具体数据\\n- message: 可选的人类可读消息\"}\n 141     ]\n 142     \n 143     payload = {\n 144         \"model\": model,\n 145         \"messages\": messages,\n 146         \"max_tokens\": 2000,\n-147         \"temperature\": 0.1\n+145         \"temperature\": 0.1,\n+146         \"response_format\": {\"type\": \"json_object\"}  # 要求 JSON 响应\n 148     }\n 149     \n 150     headers = {\n 151         \"Authorization\": f\"Bearer {api_key}\",\n 152         \"Content-Type\": \"application/json\"\n 153     }\n 154     \n-155     try:\n-156         print(f\"调用 {category} API: {url}\")\n-157         response = requests.post(url, headers=headers, json=payload, timeout=60)\n-158         response.raise_for_status()\n-159         result = response.json()\n-160         \n-161         # 解析响应（假设返回 JSON 包含执行结果）\n-162         # 这里需要根据实际 API 响应格式调整\n-163         if \"choices\" in result:\n-164             content = result[\"choices\"][0][\"message\"][\"content\"]\n-165             # 尝试解析为 JSON，否则作为文本\n-166             try:\n-167                 api_result = json.loads(content)\n-168             except json.JSONDecodeError:\n-169                 api_result = {\"output\": content, \"success\": True}\n-170         else:\n-171             api_result = result  # 假设已经是结果格式\n-172         \n-173         return api_result\n-174         \n-175     except requests.exceptions.RequestException as e:\n-176         print(f\"API 调用失败: {e}\")\n-177         return None\n-178     except json.JSONDecodeError as e:\n-179         print(f\"API 响应解析失败: {e}\")\n-180         return None\n+154     # 重试逻辑\n+155     for attempt in range(max_retries + 1):\n+156         try:\n+157             timeout = 30 * (attempt + 1)  # 逐渐增加超时\n+158             print(f\"调用 {category} API (尝试 {attempt+1}/{max_retries+1}): {url}\")\n+159             \n+160             response = requests.post(url, headers=headers, json=payload, timeout=timeout)\n+161             response.raise_for_status()\n+162             result = response.json()\n+163             \n+164             # 解析响应\n+165             if \"choices\" in result:\n+166                 content = result[\"choices\"][0][\"message\"][\"content\"]\n+167                 # 由于设置了 response_format，内容应该是 JSON\n+168                 try:\n+169                     api_result = json.loads(content)\n+170                     # 验证基本结构\n+171                     if isinstance(api_result, dict) and \"success\" in api_result:\n+172                         print(f\"API 调用成功 (尝试 {attempt+1})\")\n+173                         return api_result\n+174                     else:\n+175                         print(f\"API 响应缺少 'success' 字段: {api_result}\")\n+176                         # 仍然接受，但包装一下\n+177                         return {\"success\": True, \"data\": api_result, \"message\": \"API returned non-standard format\"}\n+178                 except json.JSONDecodeError as e:\n+179                     print(f\"API 响应不是有效的 JSON (尝试 {attempt+1}): {e}\")\n+180                     # 回退到文本处理\n+181                     return {\"success\": True, \"data\": {\"output\": content}, \"message\": \"API returned text instead of JSON\"}\n+182             else:\n+183                 # 非标准响应格式\n+184                 print(f\"API 返回非标准格式: {result.keys()}\")\n+185                 return {\"success\": True, \"data\": result, \"message\": \"API returned non-standard response\"}\n+186                 \n+187         except requests.exceptions.Timeout as e:\n+188             print(f\"API 调用超时 (尝试 {attempt+1}): {e}\")\n+189             if attempt == max_retries:\n+190                 print(f\"达到最大重试次数 ({max_retries+1})\")\n+191                 return None\n+192             print(f\"等待 2 秒后重试...\")\n+193             time.sleep(2)\n+194             \n+195         except requests.exceptions.ConnectionError as e:\n+196             print(f\"API 连接错误 (尝试 {attempt+1}): {e}\")\n+197             if attempt == max_retries:\n+198                 print(f\"达到最大重试次数 ({max_retries+1})\")\n+199                 return None\n+200             print(f\"等待 3 秒后重试...\")\n+201             time.sleep(3)\n+202             \n+203         except requests.exceptions.HTTPError as e:\n+204             print(f\"API HTTP 错误 (尝试 {attempt+1}): {e}\")\n+205             if e.response.status_code == 401:\n+206                 print(\"API 密钥无效，停止重试\")\n+207                 return None\n+208             elif e.response.status_code == 429:\n+209                 retry_after = int(e.response.headers.get('Retry-After', 5))\n+210                 print(f\"速率限制，等待 {retry_after} 秒\")\n+211                 time.sleep(retry_after)\n+212                 continue\n+213             elif 500 <= e.response.status_code < 600:\n+214                 print(\"服务器错误，重试...\")\n+215                 if attempt == max_retries:\n+216                     return None\n+217                 time.sleep(5)\n+218                 continue\n+219             else:\n+220                 print(f\"HTTP {e.response.status_code} 错误，停止重试\")\n+221                 return None\n+222                 \n+223         except requests.exceptions.RequestException as e:\n+224             print(f\"API 请求异常 (尝试 {attempt+1}): {e}\")\n+225             if attempt == max_retries:\n+226                 return None\n+227             time.sleep(2)\n+228             \n+229         except json.JSONDecodeError as e:\n+230             print(f\"响应 JSON 解析失败 (尝试 {attempt+1}): {e}\")\n+231             if attempt == max_retries:\n+232                 return None\n+233             time.sleep(1)\n+234     \n+235     print(\"所有重试尝试均失败\")\n+236     return None\n 181 \n 182 def execute_ping(params):\n 183     \"\"\"执行 ping 任务（测试用）\"\"\"\n 184     message = params.get(\"message\", \"pong\")\n     ...","firstChangedLine":110},"isError":false,"timestamp":1774608860625}}
