{"type":"message","id":"5149666b","parentId":"ac01d55c","timestamp":"2026-03-27T08:28:53.350Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建消费者脚本。消费者脚本需要读取 tasks.jsonl，找到 pending 状态的事件，将其状态改为 processing，然后执行相应的任务。需要实现锁机制，防止并发处理。可以使用文件锁（flock）。我们将创建一个 Python 脚本，由攻击者代理通过 cron 调用。\n\n创建 consume.py。它将处理一个 pending 事件，执行相应的命令，然后写入结果。为了简单起见，首先实现一个 ping 任务（执行 echo），然后扩展到其他任务。\n\n开始编写。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_6KhUEIbOa7Aswfl6SlLpMn8s","name":"write","arguments":{"path":"/home/asus/.openclaw/events/consume.py","content":"#!/usr/bin/env python3\n\"\"\"\n事件消费脚本\n由攻击者代理周期性调用，处理 pending 状态的事件。\n\"\"\"\n\nimport json\nimport sys\nimport subprocess\nimport time\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nimport fcntl  # 文件锁\n\nEVENTS_DIR = Path(__file__).parent\nTASKS_FILE = EVENTS_DIR / \"tasks.jsonl\"\nRESULTS_FILE = EVENTS_DIR / \"results.jsonl\"\nDEAD_LETTER_FILE = EVENTS_DIR / \"dead-letter.jsonl\"\n\ndef load_events():\n    \"\"\"读取所有事件\"\"\"\n    if not TASKS_FILE.exists():\n        return []\n    with open(TASKS_FILE, \"r\", encoding=\"utf-8\") as f:\n        return [json.loads(line.strip()) for line in f if line.strip()]\n\ndef save_events(events):\n    \"\"\"保存所有事件（覆盖）\"\"\"\n    with open(TASKS_FILE, \"w\", encoding=\"utf-8\") as f:\n        for event in events:\n            f.write(json.dumps(event, ensure_ascii=False) + \"\\n\")\n\ndef update_event_status(event_id, new_status, events):\n    \"\"\"更新事件状态并记录历史\"\"\"\n    for event in events:\n        if event[\"id\"] == event_id:\n            event[\"status\"] = new_status\n            event[\"statusHistory\"].append({\n                \"status\": new_status,\n                \"at\": datetime.now(timezone.utc).isoformat()\n            })\n            if new_status == \"processing\":\n                event[\"processedAt\"] = datetime.now(timezone.utc).isoformat()\n            elif new_status in (\"completed\", \"failed\"):\n                event[\"completedAt\"] = datetime.now(timezone.utc).isoformat()\n            return True\n    return False\n\ndef move_to_dead_letter(event):\n    \"\"\"将事件移至死信队列\"\"\"\n    event[\"deadLetter\"] = True\n    with open(DEAD_LETTER_FILE, \"a\", encoding=\"utf-8\") as f:\n        f.write(json.dumps(event, ensure_ascii=False) + \"\\n\")\n    print(f\"事件 {event['id']} 已移至死信队列\")\n\ndef write_result(event_id, status, raw_data, metadata):\n    \"\"\"写入结果文件\"\"\"\n    result = {\n        \"eventId\": event_id,\n        \"status\": status,\n        \"rawData\": raw_data,\n        \"metadata\": metadata,\n        \"createdAt\": datetime.now(timezone.utc).isoformat()\n    }\n    with open(RESULTS_FILE, \"a\", encoding=\"utf-8\") as f:\n        f.write(json.dumps(result, ensure_ascii=False) + \"\\n\")\n    print(f\"结果已写入: {event_id}\")\n\ndef execute_ping(params):\n    \"\"\"执行 ping 任务（测试用）\"\"\"\n    message = params.get(\"message\", \"pong\")\n    time.sleep(0.5)  # 模拟延迟\n    return {\n        \"output\": f\"Ping response: {message}\",\n        \"success\": True\n    }\n\ndef execute_scan_cmcc(params):\n    \"\"\"执行 CMCC 扫描任务\"\"\"\n    interface = params.get(\"interface\", \"wlan1\")\n    duration = params.get(\"duration\", 10)\n    # 这里应调用实际的 airodump-ng 命令，但为了测试先模拟\n    print(f\"模拟扫描: interface={interface}, duration={duration}s\")\n    time.sleep(2)\n    return {\n        \"scanResults\": [\n            {\"bssid\": \"AA:BB:CC:DD:EE:FF\", \"ssid\": \"CMCC\", \"channel\": 6},\n            {\"bssid\": \"11:22:33:44:55:66\", \"ssid\": \"CMCC-WEB\", \"channel\": 11}\n        ],\n        \"success\": True\n    }\n\ndef handle_event(event):\n    \"\"\"处理单个事件\"\"\"\n    event_id = event[\"id\"]\n    task = event[\"task\"]\n    params = event.get(\"params\", {})\n    \n    print(f\"处理事件 {event_id}: task={task}\")\n    \n    # 根据任务类型执行\n    if task == \"ping\":\n        result = execute_ping(params)\n    elif task == \"scan-cmcc\":\n        result = execute_scan_cmcc(params)\n    else:\n        result = {\"error\": f\"未知任务: {task}\", \"success\": False}\n    \n    # 构建原始数据\n    raw_data = {\n        \"task\": task,\n        \"params\": params,\n        \"executionResult\": result\n    }\n    \n    metadata = {\n        \"duration\": 2,  # 模拟执行时间\n        \"toolsUsed\": [\"airodump-ng\"] if task == \"scan-cmcc\" else []\n    }\n    \n    status = \"completed\" if result.get(\"success\") else \"failed\"\n    write_result(event_id, status, raw_data, metadata)\n    return status\n\ndef main():\n    # 文件锁，避免并发消费\n    lock_file = TASKS_FILE.with_suffix(\".lock\")\n    try:\n        with open(lock_file, \"w\") as lock:\n            fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)\n            \n            events = load_events()\n            pending_events = [e for e in events if e[\"status\"] == \"pending\"]\n            \n            if not pending_events:\n                print(\"无待处理事件\")\n                return\n            \n            # 每次只处理一个事件（避免阻塞）\n            event = pending_events[0]\n            event_id = event[\"id\"]\n            \n            # 更新状态为 processing\n            if not update_event_status(event_id, \"processing\", events):\n                print(f\"无法更新事件状态: {event_id}\")\n                return\n            save_events(events)\n            \n            # 释放锁，允许其他消费者（如果有）处理其他事件\n            fcntl.flock(lock, fcntl.LOCK_UN)\n            \n            # 处理事件（可能耗时）\n            try:\n                final_status = handle_event(event)\n            except Exception as e:\n                print(f\"处理事件时出错: {e}\")\n                final_status = \"failed\"\n            \n            # 重新加锁以更新最终状态\n            with open(lock_file, \"w\") as lock2:\n                fcntl.flock(lock2, fcntl.LOCK_EX)\n                events = load_events()\n                if not update_event_status(event_id, final_status, events):\n                    print(f\"无法更新最终状态: {event_id}\")\n                else:\n                    # 检查重试次数\n                    for ev in events:\n                        if ev[\"id\"] == event_id and final_status == \"failed\":\n                            ev[\"retryCount\"] = ev.get(\"retryCount\", 0) + 1\n                            if ev[\"retryCount\"] >= ev.get(\"maxRetries\", 3):\n                                move_to_dead_letter(ev)\n                    save_events(events)\n                \n    except BlockingIOError:\n        print(\"另一个消费者正在运行，跳过\")\n    except Exception as e:\n        print(f\"消费者出错: {e}\")\n        sys.exit(1)\n    finally:\n        # 确保锁被释放\n        try:\n            with open(lock_file, \"w\") as lock:\n                fcntl.flock(lock, fcntl.LOCK_UN)\n        except:\n            pass\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-reasoner","usage":{"input":85203,"output":1863,"cacheRead":13184,"cacheWrite":0,"totalTokens":100250,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774600047949,"responseId":"6661e97a-2db5-4fb7-ba86-c1c036e10e1b"}}
