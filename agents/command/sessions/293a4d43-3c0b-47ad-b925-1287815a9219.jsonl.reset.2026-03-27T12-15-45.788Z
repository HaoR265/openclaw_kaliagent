{"type":"message","id":"04ac7aca","parentId":"5da53f9c","timestamp":"2026-03-27T10:58:33.783Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的。现在需要更新监控脚本`status.py`和`summarize.py`以支持分片文件。当前它们只读取`tasks.jsonl`，但现在我们使用的是`tasks-YYYY-MM-DD.jsonl`。\n\n先查看`status.py`的当前实现。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_Ie38nkzYjUqeEN5LHdxIuHS0","name":"read","arguments":{"path":"/home/asus/.openclaw/events/status.py"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-reasoner","usage":{"input":22486,"output":171,"cacheRead":73216,"cacheWrite":0,"totalTokens":95873,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774609096924,"responseId":"6bd2995b-c531-49d2-be7c-6fabc58f2e5f"}}
{"type":"message","id":"5c9d7593","parentId":"04ac7aca","timestamp":"2026-03-27T10:58:33.830Z","message":{"role":"toolResult","toolCallId":"call_00_Ie38nkzYjUqeEN5LHdxIuHS0","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\n队列状态监控\n\"\"\"\n\nimport json\nfrom pathlib import Path\nfrom datetime import datetime, timezone\n\nEVENTS_DIR = Path(__file__).parent\nTASKS_FILE = EVENTS_DIR / \"tasks.jsonl\"\nRESULTS_FILE = EVENTS_DIR / \"results.jsonl\"\nDEAD_LETTER_FILE = EVENTS_DIR / \"dead-letter.jsonl\"\n\ndef count_lines(filepath):\n    if not filepath.exists():\n        return 0\n    with open(filepath, \"r\", encoding=\"utf-8\") as f:\n        return sum(1 for line in f if line.strip())\n\ndef analyze_tasks():\n    if not TASKS_FILE.exists():\n        return {\"total\": 0, \"pending\": 0, \"processing\": 0, \"completed\": 0, \"failed\": 0}\n    \n    stats = {\"total\": 0, \"pending\": 0, \"processing\": 0, \"completed\": 0, \"failed\": 0}\n    latest = None\n    with open(TASKS_FILE, \"r\", encoding=\"utf-8\") as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            try:\n                data = json.loads(line)\n                stats[\"total\"] += 1\n                status = data.get(\"status\", \"unknown\")\n                if status in stats:\n                    stats[status] += 1\n                # 记录最新事件时间\n                created = data.get(\"createdAt\")\n                if created:\n                    dt = datetime.fromisoformat(created.replace('Z', '+00:00'))\n                    if latest is None or dt > latest:\n                        latest = dt\n            except json.JSONDecodeError:\n                pass\n    stats[\"latest\"] = latest.isoformat() if latest else None\n    return stats\n\ndef main():\n    tasks = count_lines(TASKS_FILE)\n    results = count_lines(RESULTS_FILE)\n    dead = count_lines(DEAD_LETTER_FILE)\n    stats = analyze_tasks()\n    \n    print(\"事件队列状态\")\n    print(\"=\" * 40)\n    print(f\"任务文件: {TASKS_FILE.name}\")\n    print(f\"总事件数: {stats['total']}\")\n    print(f\"  待处理: {stats['pending']}\")\n    print(f\"  处理中: {stats['processing']}\")\n    print(f\"  已完成: {stats['completed']}\")\n    print(f\"  失败:   {stats['failed']}\")\n    if stats['latest']:\n        print(f\"最新事件: {stats['latest']}\")\n    print()\n    print(f\"结果数量: {results}\")\n    print(f\"死信数量: {dead}\")\n    print()\n    \n    # 检查消费者日志（如果有）\n    log_file = EVENTS_DIR / \"consumer.log\"\n    if log_file.exists():\n        with open(log_file, \"r\", encoding=\"utf-8\") as f:\n            lines = f.readlines()\n            if lines:\n                print(f\"消费者日志最后5行:\")\n                for line in lines[-5:]:\n                    print(f\"  {line.rstrip()}\")\n            else:\n                print(\"消费者日志为空\")\n    else:\n        print(\"消费者日志不存在\")\n\nif __name__ == \"__main__\":\n    main()"}],"isError":false,"timestamp":1774609113826}}
{"type":"message","id":"51a744ca","parentId":"5c9d7593","timestamp":"2026-03-27T10:59:22.223Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"需要更新这个脚本以支持分片文件。应该读取所有`tasks-*.jsonl`文件，而不仅仅是`tasks.jsonl`。还要显示按日期的分布。我来修改这个脚本。先备份原文件，然后修改。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_CoKCe6QvAGlSOTiUsitk61lk","name":"write","arguments":{"path":"/home/asus/.openclaw/events/status.py","content":"#!/usr/bin/env python3\n\"\"\"\n队列状态监控（支持分片文件）\n\"\"\"\n\nimport json\nfrom pathlib import Path\nfrom datetime import datetime, timezone, date, timedelta\nimport glob\n\nEVENTS_DIR = Path(__file__).parent\nRESULTS_FILE = EVENTS_DIR / \"results.jsonl\"\nDEAD_LETTER_FILE = EVENTS_DIR / \"dead-letter.jsonl\"\n\ndef get_task_files(days_back=7):\n    \"\"\"获取最近几天的任务文件\"\"\"\n    files = []\n    for i in range(days_back):\n        d = date.today() - timedelta(days=i)\n        filename = f\"tasks-{d.isoformat()}.jsonl\"\n        f = EVENTS_DIR / filename\n        if f.exists():\n            files.append(f)\n    # 也检查旧的非分片文件\n    old_file = EVENTS_DIR / \"tasks.jsonl\"\n    if old_file.exists():\n        files.append(old_file)\n    return files\n\ndef count_lines(filepath):\n    if not filepath.exists():\n        return 0\n    with open(filepath, \"r\", encoding=\"utf-8\") as f:\n        return sum(1 for line in f if line.strip())\n\ndef analyze_tasks():\n    \"\"\"分析所有任务文件\"\"\"\n    task_files = get_task_files()\n    \n    stats = {\n        \"total\": 0, \"pending\": 0, \"processing\": 0, \"completed\": 0, \"failed\": 0,\n        \"by_date\": {}, \"by_category\": {}\n    }\n    latest = None\n    \n    for task_file in task_files:\n        date_str = task_file.stem.replace(\"tasks-\", \"\")\n        if date_str == \"tasks\":  # 旧的非分片文件\n            date_str = \"legacy\"\n        \n        if not task_file.exists():\n            continue\n            \n        date_stats = {\"total\": 0, \"pending\": 0, \"processing\": 0, \"completed\": 0, \"failed\": 0}\n        \n        with open(task_file, \"r\", encoding=\"utf-8\") as f:\n            for line in f:\n                line = line.strip()\n                if not line:\n                    continue\n                try:\n                    data = json.loads(line)\n                    stats[\"total\"] += 1\n                    date_stats[\"total\"] += 1\n                    \n                    status = data.get(\"status\", \"unknown\")\n                    if status in stats:\n                        stats[status] += 1\n                        date_stats[status] += 1\n                    \n                    # 按类别统计\n                    category = data.get(\"category\", \"unknown\")\n                    if category not in stats[\"by_category\"]:\n                        stats[\"by_category\"][category] = 0\n                    stats[\"by_category\"][category] += 1\n                    \n                    # 记录最新事件时间\n                    created = data.get(\"createdAt\")\n                    if created:\n                        dt = datetime.fromisoformat(created.replace('Z', '+00:00'))\n                        if latest is None or dt > latest:\n                            latest = dt\n                            \n                except json.JSONDecodeError:\n                    pass\n        \n        stats[\"by_date\"][date_str] = date_stats\n    \n    stats[\"latest\"] = latest.isoformat() if latest else None\n    return stats\n\ndef main():\n    task_files = get_task_files()\n    results = count_lines(RESULTS_FILE)\n    dead = count_lines(DEAD_LETTER_FILE)\n    stats = analyze_tasks()\n    \n    print(\"事件队列状态（分片存储）\")\n    print(\"=\" * 50)\n    \n    if not task_files:\n        print(\"未找到任务文件\")\n        return\n    \n    print(f\"任务文件数: {len(task_files)}\")\n    print(f\"总事件数: {stats['total']}\")\n    print(f\"  待处理: {stats['pending']}\")\n    print(f\"  处理中: {stats['processing']}\")\n    print(f\"  已完成: {stats['completed']}\")\n    print(f\"  失败:   {stats['failed']}\")\n    \n    if stats['latest']:\n        print(f\"最新事件: {stats['latest']}\")\n    \n    print()\n    \n    # 按日期显示分布\n    if stats[\"by_date\"]:\n        print(\"按日期分布:\")\n        for date_str, date_stats in sorted(stats[\"by_date\"].items()):\n            if date_stats[\"total\"] > 0:\n                print(f\"  {date_str}: {date_stats['total']} 事件 (待处理: {date_stats['pending']}, 处理中: {date_stats['processing']}, 已完成: {date_stats['completed']})\")\n    \n    # 按类别显示分布\n    if stats[\"by_category\"]:\n        print(\"\\n按类别分布:\")\n        for category, count in sorted(stats[\"by_category\"].items()):\n            print(f\"  {category}: {count}\")\n    \n    print()\n    print(f\"结果数量: {results}\")\n    print(f\"死信数量: {dead}\")\n    print()\n    \n    # 检查消费者日志\n    log_file = EVENTS_DIR / \"consumer.log\"\n    if log_file.exists():\n        with open(log_file, \"r\", encoding=\"utf-8\") as f:\n            lines = f.readlines()\n            if lines:\n                print(f\"消费者日志最后5行:\")\n                for line in lines[-5:]:\n                    print(f\"  {line.rstrip()}\")\n            else:\n                print(\"消费者日志为空\")\n    else:\n        print(\"消费者日志不存在\")\n    \n    # 显示当前待处理事件（如果有）\n    if stats[\"pending\"] > 0:\n        print(f\"\\n当前有 {stats['pending']} 个待处理事件，下次 cron 将在下一分钟处理\")\n\nif __name__ == \"__main__\":\n    main()"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-reasoner","usage":{"input":845,"output":1388,"cacheRead":95680,"cacheWrite":0,"totalTokens":97913,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774609113832,"responseId":"17886c17-e562-492c-b08b-882ddd9d5d7f"}}
