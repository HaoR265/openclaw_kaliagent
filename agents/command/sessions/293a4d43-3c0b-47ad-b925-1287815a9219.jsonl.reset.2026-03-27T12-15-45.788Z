{"type":"message","id":"c0b407e4","parentId":"b816549d","timestamp":"2026-03-27T10:52:57.774Z","message":{"role":"toolResult","toolCallId":"call_00_pVy1ad9a5g5KYLCVr8QajHkh","toolName":"read","content":[{"type":"text","text":"    if not APIS_CONFIG.exists():\n        return {}\n    try:\n        with open(APIS_CONFIG, \"r\", encoding=\"utf-8\") as f:\n            return json.load(f)\n    except json.JSONDecodeError:\n        print(f\"API 配置文件解析失败: {APIS_CONFIG}\")\n        return {}\n\ndef load_events():\n    \"\"\"读取当天事件文件中的所有事件\"\"\"\n    tasks_file = get_tasks_file()\n    if not tasks_file.exists():\n        return []\n    with open(tasks_file, \"r\", encoding=\"utf-8\") as f:\n        return [json.loads(line.strip()) for line in f if line.strip()]\n\ndef save_events(events):\n    \"\"\"保存所有事件到当天文件（覆盖）\"\"\"\n    tasks_file = get_tasks_file()\n    with open(tasks_file, \"w\", encoding=\"utf-8\") as f:\n        for event in events:\n            f.write(json.dumps(event, ensure_ascii=False) + \"\\n\")\n\ndef update_event_status(event_id, new_status, events):\n    \"\"\"更新事件状态并记录历史\"\"\"\n    for event in events:\n        if event[\"id\"] == event_id:\n            event[\"status\"] = new_status\n            event[\"statusHistory\"].append({\n                \"status\": new_status,\n                \"at\": datetime.now(timezone.utc).isoformat()\n            })\n            if new_status == \"processing\":\n                event[\"processedAt\"] = datetime.now(timezone.utc).isoformat()\n            elif new_status in (\"completed\", \"failed\"):\n                event[\"completedAt\"] = datetime.now(timezone.utc).isoformat()\n            return True\n    return False\n\ndef move_to_dead_letter(event):\n    \"\"\"将事件移至死信队列\"\"\"\n    event[\"deadLetter\"] = True\n    with open(DEAD_LETTER_FILE, \"a\", encoding=\"utf-8\") as f:\n        f.write(json.dumps(event, ensure_ascii=False) + \"\\n\")\n    print(f\"事件 {event['id']} 已移至死信队列\")\n\ndef write_result(event_id, status, raw_data, metadata):\n    \"\"\"写入结果文件\"\"\"\n    result = {\n        \"eventId\": event_id,\n        \"status\": status,\n        \"rawData\": raw_data,\n        \"metadata\": metadata,\n        \"createdAt\": datetime.now(timezone.utc).isoformat()\n    }\n    with open(RESULTS_FILE, \"a\", encoding=\"utf-8\") as f:\n        f.write(json.dumps(result, ensure_ascii=False) + \"\\n\")\n    print(f\"结果已写入: {event_id}\")\n\ndef call_attack_api(event):\n    \"\"\"调用攻击者 API 处理事件\"\"\"\n    if not REQUESTS_AVAILABLE:\n        print(\"requests 库不可用，无法调用 API\")\n        return None\n    \n    category = event.get(\"category\")\n    if not category:\n        print(\"事件未指定类别，无法路由到 API\")\n        return None\n    \n    apis = load_apis_config()\n    if category not in apis:\n        print(f\"类别 '{category}' 未在 API 配置中定义\")\n        return None\n    \n    config = apis[category]\n    api_key = config.get(\"api_key\")\n    base_url = config.get(\"base_url\", \"https://api.deepseek.com\")\n    endpoint = config.get(\"endpoint\", \"/chat/completions\")\n    model = config.get(\"model\", \"deepseek-chat\")\n    \n    # 构建请求 URL\n    url = base_url.rstrip(\"/\") + endpoint\n    \n    # 构建请求体（根据 DeepSeek API 格式）\n    # 这里假设 API 期望标准的聊天补全格式\n    # 实际格式可能需要根据用户的 API 调整\n    messages = [\n        {\"role\": \"system\", \"content\": f\"你是 {category} 攻击者代理，执行渗透测试任务。\"},\n        {\"role\": \"user\", \"content\": f\"任务: {event['task']}\\n参数: {json.dumps(event.get('params', {}), indent=2)}\"}\n    ]\n    \n    payload = {\n        \"model\": model,\n        \"messages\": messages,\n        \"max_tokens\": 2000,\n        \"temperature\": 0.1\n    }\n    \n\n[230 more lines in file. Use offset=150 to continue.]"}],"isError":false,"timestamp":1774608777769}}
