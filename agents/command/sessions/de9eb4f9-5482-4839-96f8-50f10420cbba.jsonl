{"type":"message","id":"b4b24fcb","parentId":"2ce80f33","timestamp":"2026-03-27T16:44:35.846Z","message":{"role":"toolResult","toolCallId":"call_00_eBrNSNhYeCtaEnBwkMHZFyiO","toolName":"read","content":[{"type":"text","text":"const API = \"http://127.0.0.1:18789\";\n\nconst chat = document.getElementById(\"chat\");\nconst status = document.getElementById(\"status\");\n\nfunction log(text, cls = \"bot\") {\n  const d = document.createElement(\"div\");\n  d.className = \"msg \" + cls;\n  d.innerText = text;\n  chat.appendChild(d);\n  chat.scrollTop = chat.scrollHeight;\n}\n\nasync function send() {\n  const msgEl = document.getElementById(\"msg\");\n  const agent = document.getElementById(\"agent\").value;\n  const msg = msgEl.value.trim();\n  if (!msg) return;\n\n  log(`你 -> ${agent}: ${msg}`, \"user\");\n  msgEl.value = \"\";\n\n  try {\n    const res = await fetch(`${API}/api/agent/${agent}/run`, {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\"\n      },\n      body: JSON.stringify({\n        input: msg\n      })\n    });\n\n    const data = await res.json();\n    log(data.output || JSON.stringify(data, null, 2));\n  } catch (e) {\n    log(\"错误: \" + e.message, \"err\");\n  }\n}\n\nasync function ping() {\n  try {\n    await fetch(API);\n    status.innerText = \"已连接\";\n  } catch {\n    status.innerText = \"未连接\";\n  }\n}\n\nsetInterval(ping, 2000);\nping();\n"}],"isError":false,"timestamp":1774629875843}}
