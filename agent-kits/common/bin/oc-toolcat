#!/usr/bin/env bash
set -euo pipefail
role="${1:-offense}"
view="${2:-catalog}"
case "$role" in
  offense)
    case "$view" in
      catalog) cat /home/asus/.openclaw/agent-kits/offense-kit/catalog/front-tools.json ;;
      recipes) find /home/asus/.openclaw/agent-kits/recipes -maxdepth 1 -type f -name 'recon.*.json' -o -name 'web.*.json' -o -name 'wireless.*.json' | sort | xargs cat ;;
      policies) find /home/asus/.openclaw/agent-kits/policies -maxdepth 1 -type f | sort | xargs cat ;;
      *) echo "usage: oc-toolcat offense [catalog|recipes|policies]" >&2; exit 1 ;;
    esac
    ;;
  defense)
    case "$view" in
      catalog) cat /home/asus/.openclaw/agent-kits/defense-kit/catalog/front-tools.json ;;
      policies) find /home/asus/.openclaw/agent-kits/policies -maxdepth 1 -type f | sort | xargs cat ;;
      *) echo "usage: oc-toolcat defense [catalog|policies]" >&2; exit 1 ;;
    esac
    ;;
  command-rare)
    case "$view" in
      catalog) cat /home/asus/.openclaw/agent-kits/cmd-special/catalog/rare-tools.json ;;
      policies) find /home/asus/.openclaw/agent-kits/policies -maxdepth 1 -type f | sort | xargs cat ;;
      *) echo "usage: oc-toolcat command-rare [catalog|policies]" >&2; exit 1 ;;
    esac
    ;;
  *)
    echo "usage: oc-toolcat {offense|defense|command-rare} [catalog|recipes|policies]" >&2
    exit 1
    ;;
esac
