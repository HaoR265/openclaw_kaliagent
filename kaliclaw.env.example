# Kaliclaw（爪龙） default env example
#
# These defaults represent the final Kaliclaw runtime identity.
# Uncomment the compatibility block only when you still need to run the
# legacy OpenClaw naming during migration or rollback.

export KALICLAW_ROOT="$HOME/.kaliclaw"
export KALICLAW_CLI_BIN="kaliclaw"
export KALICLAW_CONFIG_BASENAME="kaliclaw.json"
# export KALICLAW_SOURCE_ROOT="$HOME/.openclaw"            # 仅在从旧根目录迁移时设置
# export KALICLAW_SOURCE_CONFIG_BASENAME="openclaw.json"  # 仅在从旧配置迁移时设置

# Runtime databases.
export KALICLAW_RUNTIME_DIR="$KALICLAW_ROOT/events/runtime"
export KALICLAW_DB_BASENAME="kaliclaw.db"
export KALICLAW_KNOWLEDGE_DB_BASENAME="knowledge.db"

# Uncomment these only when you need exact full-path overrides.
# export KALICLAW_DB_PATH="$KALICLAW_RUNTIME_DIR/kaliclaw.db"
# export KALICLAW_KNOWLEDGE_DB_PATH="$KALICLAW_RUNTIME_DIR/knowledge.db"

# Compatibility fallback example.
# export KALICLAW_ROOT="$HOME/.openclaw"
# export KALICLAW_CLI_BIN="openclaw"
# export KALICLAW_SOURCE_ROOT="$HOME/.openclaw"
# export KALICLAW_SOURCE_CONFIG_BASENAME="openclaw.json"
# export KALICLAW_CONFIG_BASENAME="kaliclaw.json"
# export KALICLAW_DB_BASENAME="openclaw.db"
