# Kaliclaw compatibility env example
#
# Copy this to a local shell snippet and adjust paths as needed before sourcing.
# The current defaults intentionally preserve compatibility with the legacy
# openclaw CLI/config/runtime naming until the final migration round.

export KALICLAW_ROOT="$HOME/.openclaw"
export KALICLAW_CLI_BIN="openclaw"
export KALICLAW_CONFIG_BASENAME="openclaw.json"
# export KALICLAW_SOURCE_CONFIG_BASENAME="openclaw.json"  # 仅在迁移到新配置名时设置

# Runtime databases.
export KALICLAW_RUNTIME_DIR="$KALICLAW_ROOT/events/runtime"
export KALICLAW_DB_BASENAME="openclaw.db"
export KALICLAW_KNOWLEDGE_DB_BASENAME="knowledge.db"

# Uncomment these only when you need exact full-path overrides.
# export KALICLAW_DB_PATH="$KALICLAW_RUNTIME_DIR/openclaw.db"
# export KALICLAW_KNOWLEDGE_DB_PATH="$KALICLAW_RUNTIME_DIR/knowledge.db"
